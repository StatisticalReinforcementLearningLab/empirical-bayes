   "source": [
    "def calculate_diff(a_1, a_2):\n",
    "    diff = np.zeros((n, arms))\n",
    "    avg = 0\n",
    "    \n",
    "    for i in range(len(a_1)):\n",
    "        for j in range(len(a_1[0])):\n",
    "            d = abs(a_2[i, j] - a_1[i, j])\n",
    "            diff[i, j] = d\n",
    "            avg += d\n",
    "\n",
    "    avg = avg / (len(a_1) * len(a_1[0]))\n",
    "\n",
    "    return diff, avg"
   ]
